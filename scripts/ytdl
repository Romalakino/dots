#!/bin/bash
# ytdl-cli — interactive download manager

COOKIE_FILE="$HOME/Загрузки/youtube_cookies.txt"
DOWNLOAD_DIR="$HOME/video"
QUEUE_FILE="/tmp/ytdl-queue"
PID_FILE="/tmp/ytdl-pid"
LOG_FILE="/tmp/ytdl.log"

mkdir -p "$DOWNLOAD_DIR"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

download_one() {
    local url="$1"
    echo -e "${CYAN}[$(date +%H:%M:%S)]${NC} Качаю: $url"
    yt-dlp \
        --js-runtimes "node" \
        --remote-components ejs:github \
        --cookies "$COOKIE_FILE" \
        --remux-video mp4 \
        --embed-thumbnail \
        --write-subs --write-auto-subs --sub-langs en,ru --embed-subs \
        --sponsorblock-mark all \
        --compat-options no-youtube-unavailable-videos \
        -o "$DOWNLOAD_DIR/%(title)s.%(ext)s" \
        --newline \
        "$url" 2>&1 | while IFS= read -r line; do
            if echo "$line" | grep -qP '\[download\]'; then
                echo -ne "\r${GREEN}  $line${NC}    "
            elif echo "$line" | grep -qP 'Destination:|Merging'; then
                echo -e "${YELLOW}  $line${NC}"
            elif echo "$line" | grep -qP 'ERROR|error'; then
                echo -e "${RED}  $line${NC}"
            fi
        done
    echo ""
}

worker() {
    while true; do
        if [ -f "$QUEUE_FILE" ] && [ -s "$QUEUE_FILE" ]; then
            url=$(head -1 "$QUEUE_FILE")
            sed -i '1d' "$QUEUE_FILE"
            download_one "$url"
        else
            sleep 2
        fi
    done
}

show_queue() {
    if [ ! -f "$QUEUE_FILE" ] || [ ! -s "$QUEUE_FILE" ]; then
        echo -e "  ${YELLOW}Очередь пуста${NC}"
        return
    fi
    local i=0
    while IFS= read -r line; do
        i=$((i + 1))
        echo -e "  ${CYAN}$i.${NC} $line"
    done < "$QUEUE_FILE"
}

add_to_queue() {
    local url="$1"
    echo "$url" >> "$QUEUE_FILE"
    echo -e "${GREEN}+ Добавлено:${NC} $url"
}

start_worker() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat $PID_FILE)" 2>/dev/null; then
        return
    fi
    worker &
    echo $! > "$PID_FILE"
    disown
}

stop_worker() {
    if [ -f "$PID_FILE" ]; then
        kill "$(cat $PID_FILE)" 2>/dev/null
        rm -f "$PID_FILE"
    fi
    pkill -f "ytdl-cli" 2>/dev/null
}

show_help() {
    echo -e "${CYAN}ytdl-cli${NC} — менеджер загрузок YouTube"
    echo ""
    echo "Команды:"
    echo "  <URL>        — добавить видео в очередь"
    echo "  queue        — показать очередь"
    echo "  clear        — очистить очередь"
    echo "  stop         — остановить загрузку"
    echo "  status       — статус загрузчика"
    echo "  dir          — открыть папку загрузок"
    echo "  help         — эта справка"
    echo "  quit         — выйти"
    echo ""
}

clear_screen() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║     ytdl-cli — YouTube Downloader   ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  Загрузки: ${GREEN}$DOWNLOAD_DIR${NC}"
    echo -e "  Введите URL или 'help' для справки"
    echo ""
}

# Handle signals
trap 'stop_worker; exit 0' INT TERM

case "$1" in
    # Non-interactive mode: ytdl-cli add URL
    add)
        start_worker
        add_to_queue "$2"
        ;;
    # Non-interactive: ytdl-cli queue
    queue)
        show_queue
        ;;
    # Non-interactive: ytdl-cli stop
    stop)
        stop_worker
        echo -e "${RED}Загрузчик остановлен${NC}"
        ;;
    # Interactive mode (default)
    *)
        clear_screen
        start_worker

        while true; do
            echo -ne "${GREEN}ytdl>${NC} "
            read -r input

            case "$input" in
                quit|exit|q)
                    echo -e "${YELLOW}Выход...${NC}"
                    break
                    ;;
                help|h|\?)
                    show_help
                    ;;
                queue|q!)
                    echo -e "${CYAN}Очередь:${NC}"
                    show_queue
                    ;;
                clear)
                    > "$QUEUE_FILE"
                    echo -e "${GREEN}Очередь очищена${NC}"
                    ;;
                stop)
                    # Re-queue current and stop
                    stop_worker
                    echo -e "${RED}Загрузчик остановлен${NC}"
                    start_worker
                    ;;
                status|s)
                    if [ -f "$PID_FILE" ] && kill -0 "$(cat $PID_FILE)" 2>/dev/null; then
                        local_count=$(wc -l < "$QUEUE_FILE" 2>/dev/null || echo 0)
                        echo -e "${GREEN}Работает${NC} | В очереди: $local_count"
                    else
                        echo -e "${RED}Остановлен${NC}"
                    fi
                    ;;
                dir|d)
                    xdg-open "$DOWNLOAD_DIR" &
                    ;;
                "")
                    ;;
                *)
                    if echo "$input" | grep -qP '^https?://'; then
                        add_to_queue "$input"
                    else
                        echo -e "${RED}Неверный URL. Используйте http:// или https://${NC}"
                    fi
                    ;;
            esac
        done
        ;;
esac
