#!/bin/bash
# Screenshot: select area, save to ~/Pictures/, copy to clipboard
FILE=~/Pictures/shot-$(date +%Y%m%d%H%M%S).png
grim -g "$(slurp)" "$FILE" || exit 1
wl-copy --type image/png < "$FILE" 2>/dev/null
xclip -selection clipboard -t image/png -i "$FILE" 2>/dev/null
notify-send "Screenshot" "Saved to $FILE"
