# Sway config — Monochrome Theme
set $mod Mod4
floating_modifier $mod
seat * xcursor_theme Bibata-Modern-Ice 20
exec env XCURSOR_THEME=Bibata-Modern-Ice XCURSOR_SIZE=20
exec systemctl --user import-environment XCURSOR_THEME XCURSOR_SIZE 2>/dev/null

# Apps
bindsym --to-code $mod+t exec foot
bindsym --to-code $mod+w exec firefox
bindsym --to-code $mod+c exec /home/vlad/.local/bin/opencode-loader.sh
bindsym --to-code $mod+d exec /usr/bin/Telegram
bindsym --to-code $mod+space exec wofi --show drun
bindsym --to-code $mod+e exec nautilus --new-window
bindsym --to-code $mod+n exec nautilus

# Kill / Reload / Exit
bindsym --to-code $mod+q kill
bindsym --to-code $mod+Shift+c reload
bindsym --to-code $mod+Shift+e exec swaymsg exit

# Screenshot
bindsym --to-code $mod+Shift+s exec ~/.local/bin/screenshot
bindsym --to-code $mod+Shift+v exec ~/.local/bin/screenshot
bindsym Print exec ~/.local/bin/screenshot

# Clipboard history
bindsym --to-code $mod+Alt+c exec clipman pick -d wofi

# Audio
exec pipewire && wireplumber
bindsym XF86AudioRaiseVolume exec ~/.local/bin/notify-volume up
bindsym XF86AudioLowerVolume exec ~/.local/bin/notify-volume down
bindsym XF86AudioMute exec ~/.local/bin/notify-volume mute

# Brightness
bindsym XF86MonBrightnessUp exec ~/.local/bin/notify-brightness up
bindsym XF86MonBrightnessDown exec ~/.local/bin/notify-brightness down

# VPN
bindsym --to-code $mod+Alt+v exec /home/vlad/.local/bin/vpn-toggle toggle
bindsym --to-code $mod+Alt+y exec /home/vlad/.local/bin/proxy-toggle toggle
bindsym --to-code $mod+u exec /home/vlad/.local/bin/vpn-menu


# Power menu
bindsym --to-code $mod+p exec /home/vlad/.local/bin/power-menu

# Focus
bindsym --to-code $mod+h focus left
bindsym --to-code $mod+j focus down
bindsym --to-code $mod+k focus up
bindsym --to-code $mod+l focus right

# Move
bindsym --to-code $mod+Shift+h move left
bindsym --to-code $mod+Shift+j move down
bindsym --to-code $mod+Shift+k move up
bindsym --to-code $mod+Shift+l move right

# Layout
bindsym --to-code $mod+v split v
bindsym --to-code $mod+f fullscreen
bindsym --to-code $mod+s layout stacking

# Float
bindsym --to-code $mod+Shift+space floating toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym --to-code $mod+1 workspace number $ws1
bindsym --to-code $mod+2 workspace number $ws2
bindsym --to-code $mod+3 workspace number $ws3
bindsym --to-code $mod+4 workspace number $ws4
bindsym --to-code $mod+5 workspace number $ws5
bindsym --to-code $mod+6 workspace number $ws6
bindsym --to-code $mod+7 workspace number $ws7
bindsym --to-code $mod+8 workspace number $ws8
bindsym --to-code $mod+9 workspace number $ws9
bindsym --to-code $mod+0 workspace number $ws10

workspace 1 output HDMI-A-1 eDP-1

bindsym --to-code $mod+Shift+1 move container to workspace number $ws1
bindsym --to-code $mod+Shift+2 move container to workspace number $ws2
bindsym --to-code $mod+Shift+3 move container to workspace number $ws3
bindsym --to-code $mod+Shift+4 move container to workspace number $ws4
bindsym --to-code $mod+Shift+5 move container to workspace number $ws5
bindsym --to-code $mod+Shift+6 move container to workspace number $ws6
bindsym --to-code $mod+Shift+7 move container to workspace number $ws7
bindsym --to-code $mod+Shift+8 move container to workspace number $ws8
bindsym --to-code $mod+Shift+9 move container to workspace number $ws9
bindsym --to-code $mod+Shift+0 move container to workspace number $ws10

# Move window to workspace and follow
bindsym --to-code $mod+Alt+1 move container to workspace number $ws1; workspace number $ws1
bindsym --to-code $mod+Alt+2 move container to workspace number $ws2; workspace number $ws2
bindsym --to-code $mod+Alt+3 move container to workspace number $ws3; workspace number $ws3
bindsym --to-code $mod+Alt+4 move container to workspace number $ws4; workspace number $ws4
bindsym --to-code $mod+Alt+5 move container to workspace number $ws5; workspace number $ws5
bindsym --to-code $mod+Alt+6 move container to workspace number $ws6; workspace number $ws6
bindsym --to-code $mod+Alt+7 move container to workspace number $ws7; workspace number $ws7
bindsym --to-code $mod+Alt+8 move container to workspace number $ws8; workspace number $ws8
bindsym --to-code $mod+Alt+9 move container to workspace number $ws9; workspace number $ws9
bindsym --to-code $mod+Alt+0 move container to workspace number $ws10; workspace number $ws10

# Resize
mode "resize" {
    bindsym --to-code h resize shrink width 10 px or 10 ppt
    bindsym --to-code j resize grow height 10 px or 10 ppt
    bindsym --to-code k resize shrink height 10 px or 10 ppt
    bindsym --to-code l resize grow width 10 px or 10 ppt
    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
}
bindsym --to-code $mod+r mode "resize"

# Input
input type:keyboard {
    xkb_layout "us,ru"
    xkb_options "grp:caps_toggle"
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    pointer_accel 0.6
}

# Wallpaper
exec swaybg -i /home/vlad/.local/share/wallpapers/mt-fuji-bw.jpg -m fill

# Clipboard manager
exec wl-paste --type text --watch clipman store
exec wl-paste --type image --watch clipman store

# Dark theme for GTK apps
exec dbus-update-activation-environment --systemd GTK_THEME GTK_APPLICATION_PREFER_DARK_THEME GDK_SCALE GDK_DPI_SCALE XDG_DATA_DIRS 2>/dev/null
exec systemctl --user import-environment GTK_THEME GTK_APPLICATION_PREFER_DARK_THEME GDK_SCALE GDK_DPI_SCALE XDG_DATA_DIRS XCURSOR_THEME XCURSOR_SIZE 2>/dev/null

# D-Bus session
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY DBUS_SESSION_BUS_ADDRESS 2>/dev/null

# Output
output eDP-1 scale 1.5
output HDMI-A-1 mode 3440x1440@100Hz
exec ~/.local/bin/monitor-detect
bindsym --to-code $mod+m exec ~/.local/bin/monitor-detect
bindsym --to-code $mod+Alt+o exec ~/.local/bin/output-toggle
bindsym --to-code $mod+Alt+l exec ~/.local/bin/lid-toggle

# Appearance — Catppuccin Mocha
default_border pixel 3
default_floating_border pixel 3
gaps inner 8
gaps outer 4
smart_gaps on
smart_borders on


# Colors — Monochrome
#                       border      bg          text        indicator   child_border
client.focused          #ffffff     #ffffff     #000000     #ffffff     #ffffff
client.focused_inactive #333333     #333333     #ffffff     #333333     #333333
client.unfocused        #222222     #222222     #888888     #222222     #222222
client.urgent           #ffffff     #ffffff     #000000     #ffffff     #ffffff
client.placeholder      #222222     #222222     #ffffff     #222222     #222222

# Bar
bar {
    swaybar_command waybar
}

# Lock
bindsym --to-code $mod+x exec swaylock -c 000000

# Window rules
for_window [app_id="org.gnome.Nautilus"] floating enable, border pixel 3, resize set width 800 height 600
