# Mako notification config — Monochrome

font=JetBrainsMono Nerd Font 11
format=<b>%s</b>\n%b
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=0
layer=overlay
sort=-time
anchor=top-center
margin=20
padding=15
width=320
height=400
border-radius=0
border-size=2
max-history=20

background-color=#000000
text-color=#ffffff
border-color=#ffffff

[urgency=low]
border-color=#666666

[urgency=high]
default-timeout=0
border-color=#ffffff
